#!/bin/bash
#
# Pre-commit hook: Auto-update graphify knowledge graph before commits
# Install this hook by running: git config core.hooksPath .githooks
#
# This hook ensures the knowledge graph stays fresh as code changes.
# It runs AST-only updates (no LLM cost) on locally modified Python files.

set -e

# Colors for output
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo -e "${YELLOW}[graphify-hook] Checking for Python file changes...${NC}"

# Get list of staged Python files
PYTHON_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.py$' || true)

if [ -z "$PYTHON_FILES" ]; then
    echo -e "${GREEN}[graphify-hook] No Python files changed, skipping update${NC}"
    exit 0
fi

# Count files
FILE_COUNT=$(echo "$PYTHON_FILES" | wc -l)
echo -e "${YELLOW}[graphify-hook] Found $FILE_COUNT Python file(s) changed${NC}"

# Run graphify update (AST-only, no LLM cost)
echo -e "${YELLOW}[graphify-hook] Updating knowledge graph...${NC}"

if command -v graphify &> /dev/null; then
    # Update only the affected paths (fast, AST-only)
    graphify . --update --no-viz 2>/dev/null || {
        echo -e "${YELLOW}[graphify-hook] Graph update failed, but continuing with commit${NC}"
        exit 0
    }
    
    # Stage the updated graph files if they changed
    if [ -d "graphify-out" ]; then
        git add graphify-out/ 2>/dev/null || true
    fi
    
    echo -e "${GREEN}[graphify-hook] Knowledge graph updated ✓${NC}"
else
    echo -e "${YELLOW}[graphify-hook] graphify not in PATH${NC}"
    echo -e "${YELLOW}[graphify-hook] Install: uv tool install graphifyy${NC}"
    echo -e "${YELLOW}[graphify-hook] Add to PATH: C:\\Users\\amita\\.local\\bin${NC}"
    echo -e "${YELLOW}[graphify-hook] Skipping automatic graph update${NC}"
fi

exit 0
